{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "hardened-default",
  "description": "Enables critical permissions with hardened security boundaries. Note: FS operations are handled in Rust with strict path guarding.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:default",
    "global-shortcut:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "fs:allow-read-file"
  ]
}
