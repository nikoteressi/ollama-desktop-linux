{
  "name": "alpaka-desktop",
  "version": "1.2.0",
  "description": "Native Linux desktop client for Ollama",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --fix",
    "lint:check": "eslint src --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "e2e:build": "pnpm tauri build --features test-mode --config src-tauri/tauri.test.conf.json",
    "e2e:smoke": "NODE_OPTIONS='--import tsx' wdio run e2e-desktop/wdio.smoke.conf.ts",
    "e2e:integration": "NODE_OPTIONS='--import tsx' wdio run e2e-desktop/wdio.integration.conf.ts",
    "e2e:all": "pnpm e2e:smoke && pnpm e2e:integration"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "@types/katex": "^0.16.0",
    "@types/markdown-it": "^14.1.0",
    "@vueuse/core": "^11.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.2",
    "katex": "^0.16.0",
    "lodash.throttle": "^4.1.1",
    "markdown-it": "^14.1.0",
    "markdown-it-footnote": "^4.0.0",
    "pinia": "^2.2.0",
    "shiki": "^1.22.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.0",
    "vue-virtual-scroller": "^2.0.0-beta.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/lodash.throttle": "^4.1.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.9.1",
    "@wdio/cli": "^8",
    "@wdio/local-runner": "^8",
    "@wdio/mocha-framework": "^8",
    "@wdio/spec-reporter": "^8",
    "@wdio/types": "^8",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "happy-dom": "^20.8.9",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.2",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0",
    "webdriverio": "^8"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.2": "3.1.5",
      "serialize-javascript@<7.0.0": "7.0.5",
      "tar-fs@<3.1.2": "3.1.2",
      "ws@<8.17.1": "8.17.1"
    }
  }
}